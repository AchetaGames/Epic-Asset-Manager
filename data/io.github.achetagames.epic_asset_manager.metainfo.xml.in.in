<?xml version="1.0" encoding="UTF-8"?>
<!-- Milan Stastny 2019 <milan@acheta.games> -->
<component type="desktop-application">
    <id>@app-id@</id>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>MIT</project_license>
    <name>Epic Asset Manager</name>
    <summary>Manage your Epic assets</summary>
    <icon type="remote" height="256" width="256">https://github.com/AchetaGames/Epic-Asset-Manager/raw/main/data/icons/io.github.achetagames.epic_asset_manager.png</icon>
    <description>
        <p>An unofficial client to install Unreal Engine, download and manage purchased assets, projects, plugins and games from the Epic Games Store</p>
        <p>Features:</p>
        <ul>
            <li>Downloading purchased assets from unreal marketplace</li>
            <li>Downloading official binary Unreal Engine packages</li>
            <li>Adding assets to projects and creating new projects from assets</li>
            <li>Listing and launching Unreal projects</li>
            <li>Listing and launching Unreal Engine installations</li>
        </ul>
    </description>
    <categories>
        <category>Development</category>
        <category>Utility</category>
        <category>Network</category>
        <category>Game</category>
        <category>GTK</category>
        <category>FileTools</category>
    </categories>
    <keywords>
        <keyword>unreal</keyword>
        <keyword>engine</keyword>
        <keyword>gamedev</keyword>
        <keyword>assets</keyword>
        <keyword>epic</keyword>
    </keywords>
